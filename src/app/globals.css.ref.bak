@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&display=swap');

:root {
  --color-bg: #F8F4F0; /* Bone / Parchment */
  --color-text: #1A1A1A;
  --color-dark: #322C2B; /* Deep Umber */
  --color-white: #FFFFFF;
  --color-accent: #2E3B2E; /* Forest Green */
  --color-cyber-matcha: #A8B490; /* Muted Matcha / Sage */
  
  --font-heading: 'Playfair Display', serif;
  --font-body: 'Cormorant Garamond', serif;
  
  --max-width: 1400px;
  --transition-smooth: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  --transition-fast: all 0.3s ease;
}

* {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

body {
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  transition: var(--transition-smooth);
}

.smooth-bg {
  transition: background-color 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: normal;
  line-height: 1.1;
  margin-bottom: 1rem;
}

a {
  color: inherit;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

a:hover {
  opacity: 0.8;
}

button {
  cursor: pointer;
  font-family: var(--font-heading);
  border: none;
  background: none;
}

/* Utilities */
.noise-overlay {
  position: relative;
}

.noise-overlay::before {
  content: "";
  position: fixed;
  top: 0; left: 0; width: 100%; height: 100%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2003/svg'%3%3Ffilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  opacity: 0.03;
  pointer-events: none;
  z-index: 9999;
}

.sticker {
  display: inline-block;
  padding: 0.5rem 1rem;
  background: var(--color-cyber-matcha);
  color: #000;
  font-weight: 800;
  text-transform: uppercase;
  font-size: 0.7rem;
  transform: rotate(-5deg);
  border: 2px solid #000;
  box-shadow: 4px 4px 0px #000;
}

.container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 5%;
}

.btn {
  display: inline-block;
  background-color: var(--color-text);
  color: var(--color-white);
  padding: 1rem 2rem;
  border-radius: 50px;
  font-size: 1.1rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: transform 0.2s ease, background-color 0.2s ease;
}

.btn:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}

.btn-matcha {
  background-color: var(--color-accent-matcha);
  color: var(--color-white);
}

.btn-plum {
  background-color: var(--color-accent-plum);
  color: var(--color-white);
}

.editorial-border {
  border: 0.5px solid rgba(50, 44, 43, 0.1);
}

.bg-forest {
  background-color: var(--color-accent);
}

.text-bone {
  color: var(--color-bg);
}
