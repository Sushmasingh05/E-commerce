.hero {
  height: 100vh;
  background-color: var(--color-dark);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  perspective: 2000px;
  background-image: 
    linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.8)),
    url('https://images.unsplash.com/photo-1443548570561-aa76a4d7126b?q=80&w=2070&auto=format&fit=crop');
  background-size: cover;
  background-position: center;
}

.content {
  z-index: 10;
  text-align: center;
  width: 100%;
}

.titleWrapper {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 1rem;
}

.giantTitle {
  font-size: clamp(4rem, 20vw, 15rem);
  color: var(--color-cyber-matcha);
  line-height: 0.8;
  margin: 0;
  letter-spacing: -0.05em;
  font-weight: 800;
}

.giantTitleOutline {
  font-size: clamp(4rem, 20vw, 15rem);
  color: transparent;
  -webkit-text-stroke: 2px var(--color-cyber-matcha);
  line-height: 0.8;
  margin: 0;
  letter-spacing: -0.05em;
  font-weight: 800;
}

.subtitle {
  font-family: var(--font-body);
  color: #FFF;
  font-size: 1.5rem;
  font-weight: 500;
  letter-spacing: 2px;
  text-transform: uppercase;
  opacity: 0.8;
}

.marquee {
  position: absolute;
  bottom: 10%;
  left: 0;
  width: 100%;
  background: var(--color-cyber-matcha);
  padding: 1rem 0;
  transform: rotate(-1deg);
  overflow: hidden;
  border-top: 2px solid #000;
  border-bottom: 2px solid #000;
}

.marqueeInner {
  display: flex;
  white-space: nowrap;
}

.marqueeInner span {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 800;
  color: #000;
}

.scrollIndicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  color: var(--color-cyber-matcha);
  font-size: 2rem;
  font-weight: 800;
}

.noiseOverlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2003/svg'%3%3Ffilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
  opacity: 0.2;
  pointer-events: none;
}
